{
  "name": "spectacles",
  "version": "0.0.0",
  "description": "Spec-driven contract testing and property-based test generation for TypeScript",
  "keywords": [
    "typescript",
    "contracts",
    "contract-testing",
    "property-based-testing",
    "fast-check",
    "zod",
    "vitest",
    "ts-morph"
  ],
  "license": "MIT",
  "author": "Samuel Cook",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "spectacles": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vitest": {
      "types": "./dist/vitest.d.ts",
      "import": "./dist/vitest.js"
    },
    "./discovery": {
      "types": "./dist/discovery.d.ts",
      "import": "./dist/discovery.js"
    },
    "./planning": {
      "types": "./dist/planning.d.ts",
      "import": "./dist/planning.js"
    },
    "./rendering": {
      "types": "./dist/rendering.d.ts",
      "import": "./dist/rendering.js"
    },
    "./generation": {
      "types": "./dist/generation.d.ts",
      "import": "./dist/generation.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "npm run typecheck && npm test",
    "generate": "node ./dist/cli.js generate --help",
    "pack:preview": "npm pack --dry-run",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fast-check": "^4.8.0",
    "ts-morph": "^28.0.0"
  },
  "peerDependencies": {
    "vitest": "^3.2.4",
    "zod": "^4.4.3"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "@vitest/coverage-v8": "^3.2.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "zod": "^4.4.3"
  }
}
