{
  "name": "spectacles",
  "version": "0.0.0",
  "description": "A spec-driven development framework for TypeScript",
  "keywords": [
    "ai",
    "spec",
    "sdd",
    "ts",
    "framework",
    "testing"
  ],
  "license": "MIT",
  "author": "Samuel Cook",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vitest": {
      "types": "./dist/vitest.d.ts",
      "import": "./dist/vitest.js"
    },
    "./discovery": {
      "types": "./dist/discovery.d.ts",
      "import": "./dist/discovery.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fast-check": "^4.8.0",
    "ts-morph": "^28.0.0",
    "vitest": "^3.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.6",
    "typescript": "^5.9.3"
  }
}
